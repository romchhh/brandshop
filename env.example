# Скопіюйте у файл .env у корені репозиторію (поруч із docker-compose.yml).
# Після змін перезапустіть контейнери: docker compose up -d --build

# PostgreSQL (обовʼязково непорожні значення для Docker; інакше Django: ImproperlyConfigured NAME)
POSTGRES_DB=your_db_name
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
# У Docker з сервісом project_db залиште порожнім або явно: POSTGRES_HOST=project_db
# Окрема машина / зовнішній Postgres: POSTGRES_HOST=10.0.0.5 та POSTGRES_PORT=5432
POSTGRES_HOST=
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0

# Публічна адреса API (без / в кінці), щоб у JSON були абсолютні URL фото (/media/...).
# Якщо порожньо — Django віддає лише /media/...; тоді на клієнті обовʼязково NEXT_PUBLIC_API_HOST той самий базовий URL.
# Приклад: https://api.brandshop.in.ua
API_PUBLIC_URL=

# Локальний запуск бота без Docker — базовий URL Django API:
# SERVER_URL=http://127.0.0.1:8000
# У Docker Compose використовуйте ім'я сервісу Django (у цьому репо — server), не container_name з підкресленням:
# SERVER_URL=http://server:8000

# Next.js (client) у Docker: збірка має знати внутрішній URL Django для image optimizer (ім’я сервісу Compose).
# За замовчуванням у docker-compose вже підставляється http://server:8000
# NEXT_PUBLIC_IMAGE_UPSTREAM=http://server:8000
# NEXT_PUBLIC_API_HOST=http://localhost:8000
