# Скопіюйте у файл .env у корені репозиторію (поруч із docker-compose.yml).
# Після змін перезапустіть контейнери: docker compose up -d --build

# PostgreSQL (обовʼязково непорожні значення для Docker; інакше Django: ImproperlyConfigured NAME)
POSTGRES_DB=your_db_name
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
# У Docker з сервісом project_db залиште порожнім або явно: POSTGRES_HOST=project_db
# Окрема машина / зовнішній Postgres: POSTGRES_HOST=10.0.0.5 та POSTGRES_PORT=5432
POSTGRES_HOST=
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0

# Telegram: сповіщення адміну про імпорт каталогу (той самий бот, що й BOT_TOKEN у docker-compose для server)
# ADMIN_ID=123456789
# ADMIN_IDS=111111111,222222222

# Публічна адреса API (без / в кінці), щоб у JSON були абсолютні URL фото (/media/...).
# Якщо порожньо — Django віддає лише /media/...; тоді на клієнті обовʼязково NEXT_PUBLIC_API_HOST той самий базовий URL.
# Приклад: https://api.brandshop.in.ua
API_PUBLIC_URL=

# Куди Django зберігає завантажені фото (імпорт, адмінка). Каталог у БД лишається product_photos/... відносно MEDIA_ROOT.
# Порожньо — у репозиторії це server/media (як раніше).
# На VPS (рекомендовано, щоб nginx www-data міг читати без chmod /root):
#   DJANGO_MEDIA_ROOT=/var/www/brandshop/media
#   mkdir -p /var/www/brandshop/media && chown -R www-data:www-data /var/www/brandshop/media
# nginx має збігатися:
#   location /media/ { alias /var/www/brandshop/media/; ... }
# Якщо клієнт у Docker з NEXT_PUBLIC_MEDIA_SAME_ORIGIN=1 — змонтуйте той самий каталог у client (див. MEDIA_VOLUME_HOST_PATH у docker-compose).
# DJANGO_MEDIA_ROOT=

# Локальний запуск бота без Docker — базовий URL Django API:
# SERVER_URL=http://127.0.0.1:8000
# У Docker Compose використовуйте ім'я сервісу Django (у цьому репо — server), не container_name з підкресленням:
# SERVER_URL=http://server:8000

# Next.js (client): публічна адреса API — ТА САМА що у API_PUBLIC_URL (інакше фото в каталозі лишаться плейсхолдером).
# Приклад прод: NEXT_PUBLIC_API_HOST=https://api.brandshop.in.ua
# Локально: NEXT_PUBLIC_API_HOST=http://localhost:8000
# NEXT_PUBLIC_API_HOST=http://localhost:8000
#
# Внутрішній URL Django лише для image optimizer у Docker (ім’я сервісу Compose):
# NEXT_PUBLIC_IMAGE_UPSTREAM=http://server:8000

# Гостовий шлях до медіа для volume client (якщо DJANGO_MEDIA_ROOT не стандартний ./server/media).
# Приклад: MEDIA_VOLUME_HOST_PATH=/var/www/brandshop/media
# MEDIA_VOLUME_HOST_PATH=

# Фото товарів з тієї ж папки, що й Django MEDIA (server/media), без зовнішнього домену в URL:
# 1 — у браузері src=/media/product_photos/... (той самий хост, що й Next). У docker-compose змонтовано ./server/media → client public/media.
# 0 — як раніше: до /media/... додається NEXT_PUBLIC_API_HOST (або повний URL з API).
# NEXT_PUBLIC_MEDIA_SAME_ORIGIN=1

# Скільки секунд браузер може кешувати GET /api/catalogs* та /api/promotional-products (за замовчуванням 120).
# API_PUBLIC_CACHE_MAX_AGE=120

# Celery: щоденний імпорт товарів з Google Таблиць (django-celery-beat, локальний час CELERY_TIMEZONE).
# За замовчуванням у Django: 10 і 18 (ранок і вечір). Щоб змінити години: список через кому, напр. 9,12,21
# CATALOG_SYNC_CRON_HOURS=10,18
# Часовий пояс для crontab (наприклад Europe/Kyiv):
# CELERY_TIMEZONE=Europe/Kyiv

# Імпорт фото з Google Drive: у Google Cloud Console увімкніть «Google Drive API» для проєкту service account.
# У Drive надайте доступ до папки/файлів з таблиці користувачу = client_email з credentials.json (Поділитися).
